@model CaseAeC.Models.LoginViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4 card-dark">
            <h3 class="text-center mb-4">Acesso ao Sistema</h3>

            @if (ViewBag.Erro != null)
            {
                <div class="alert alert-danger p-2 small">@ViewBag.Erro</div>
            }

            <form asp-action="Login" method="post">
                <div class="mb-3">
                    <label class="form-label">Usuário</label>
                    <input asp-for="Login" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Senha</label>
                    <div class="input-group">
                        <input asp-for="Senha" id="pwdLogin" type="password" class="form-control" required />
                        <button class="btn" type="button" onclick="togglePass('pwdLogin', 'iconLogin')">
                            <i id="iconLogin" class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary w-100 mb-3">Entrar</button>
            </form>

            <hr class="border-secondary">

<div class="text-center">
    <a href="/Usuarios/Create" class="btn btn-outline-info btn-sm w-100">
        Não tem conta? Cadastre-se aqui
    </a>
           </div>
        </div>
    </div>
</div>
