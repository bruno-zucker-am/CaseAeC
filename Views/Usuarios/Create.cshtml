@model CaseAeC.Models.Usuario

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 card-dark">
            <h2 class="mb-4 text-center">Criar Conta</h2>

            <form asp-action="Create">
                <div class="mb-3">
                    <label class="form-label">Nome Completo</label>
                    <input asp-for="Nome" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Usuário (Login)</label>
                    <input asp-for="Login" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Senha</label>
                    <div class="input-group">
                        <input asp-for="Senha" id="pwdCreate" type="password" class="form-control" required />
                        <button class="btn" type="button" onclick="togglePass('pwdCreate', 'iconCreate')">
                            <i id="iconCreate" class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 mb-3">Salvar Cadastro</button>
            </form>

            <hr class="border-secondary">

            <div class="text-center">
                <a asp-action="Login" class="btn btn-outline-info btn-sm w-100">
                    <i class="bi bi-arrow-left"></i> Já tenho conta? Voltar ao Login
                </a>
            </div>
        </div>
    </div>
</div>
