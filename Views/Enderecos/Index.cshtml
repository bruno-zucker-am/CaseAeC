@model IEnumerable<CaseAeC.Models.Endereco>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Meus Endereços</h2>
        <div>
            <a asp-action="ExportarCsv" class="btn btn-outline-success me-2">Exportar CSV</a>
            <a asp-action="Create" class="btn btn-primary">Adicionar Novo Endereço</a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-dark text-center shadow border-secondary py-5">
            <p class="mb-0 text-secondary fs-4">Nenhum endereço encontrado.</p>
            <small class="text-muted">Parece que sua lista está vazia. Clique no botão azul para cadastrar seu primeiro endereço.</small>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover">
                <thead>
                    <tr>
                        <th>CEP</th>
                        <th>Logradouro</th>
                        <th>Nº</th>
                        <th>Complemento</th>
                        <th>Bairro</th>
                        <th>Cidade/UF</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Cep</td>
                            <td>@item.Logradouro</td>
                            <td>@item.Numero</td>
                            <td>@item.Complemento</td>
                            <td>@item.Bairro</td>
                            <td>@item.Cidade / @item.Uf</td>
                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                                    
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Tem certeza que deseja excluir este endereço?');">
                                        <button type="submit" class="btn btn-sm btn-danger">Excluir</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
